          "type": "mysql",
          "uid": "${DS_MYSQL}"
        },
        "definition": "SELECT DISTINCT profile_id FROM metric_value_day ORDER BY profile_id",
        "query": "SELECT DISTINCT profile_id FROM metric_value_day ORDER BY profile_id",
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": false,
