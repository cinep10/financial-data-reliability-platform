        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE risk_status WHEN 'normal' THEN 0 WHEN 'warning' THEN 1 WHEN 'alert' THEN 2 ELSE -1 END AS value\nFROM data_risk_score_day_v3\nWHERE profile_id='${profile_id}'\nORDER BY dt DESC\nLIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NORMAL",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "WARNING",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "ALERT",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "Risk Contribution by Signal Group",
      "type": "timeseries",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  dt AS time,\n  signal_group AS metric,\n  SUM(weighted_contribution) AS value\nFROM risk_signal_link_day\nWHERE profile_id='${profile_id}'\n  AND $__timeFilter(dt)\nGROUP BY dt, signal_group\nORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
