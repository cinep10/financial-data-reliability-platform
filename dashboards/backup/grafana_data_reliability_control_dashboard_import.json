      "type": "table",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  dt,\n  cause_rank,\n  cause_type,\n  cause_code,\n  confidence,\n  driver_source,\n  related_metric,\n  observed_value,\n  baseline_value,\n  detail\nFROM data_risk_root_cause_day\nWHERE profile_id='${profile_id}'\n  AND $__timeFilter(dt)\nORDER BY dt DESC, cause_rank ASC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
