          "rawSql": "SELECT\n  dt AS time,\n  metric_name AS metric,\n  ABS(zscore_7d) AS value\nFROM metric_time_anomaly_day\nWHERE profile_id='${profile_id}'\n  AND anomaly_status IN ('warn','alert')\n  AND $__timeFilter(dt)\nORDER BY time",
