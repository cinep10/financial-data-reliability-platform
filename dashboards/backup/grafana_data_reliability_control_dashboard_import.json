          "rawQuery": true,
          "rawSql": "SELECT\n  dt AS time,\n  pair_name AS metric,\n  ABS(ratio_diff_pct) * 100 AS value\nFROM metric_correlation_anomaly_day\nWHERE profile_id='${profile_id}'\n  AND anomaly_status IN ('warn','alert')\n  AND $__timeFilter(dt)\nORDER BY time",
