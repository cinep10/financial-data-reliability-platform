      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  dt,\n  metric_name,\n  metric_group,\n  observed_value,\n  rolling_avg_7d,\n  rolling_std_7d,\n  zscore_7d,\n  anomaly_status,\n  severity,\n  note\nFROM metric_time_anomaly_day\nWHERE profile_id='${profile_id}'\n  AND $__timeFilter(dt)\nORDER BY dt DESC, ABS(zscore_7d) DESC, metric_name",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
