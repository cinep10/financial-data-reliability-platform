          "rawQuery": true,
          "rawSql": "SELECT\n  dt,\n  pair_name,\n  left_metric,\n  right_metric,\n  baseline_ratio,\n  observed_ratio,\n  ratio_diff,\n  ratio_diff_pct,\n  anomaly_status,\n  severity,\n  note\nFROM metric_correlation_anomaly_day\nWHERE profile_id='${profile_id}'\n  AND $__timeFilter(dt)\nORDER BY dt DESC, ABS(ratio_diff_pct) DESC, pair_name",
