          "rawSql": "SELECT\n  time,\n  metric_name AS metric,\n  metric_value AS value\nFROM (\n  SELECT TIMESTAMP(dt, MAKETIME(hh, 0, 0)) AS time, profile_id, metric_name, metric_value\n  FROM metric_value_hh\n) t\nWHERE profile_id = '${profile_id}'\n  AND metric_name IN ('raw_event_count', 'collector_event_count', 'page_view_count')\n  AND $__timeFilter(time)\nORDER BY time",
          "refId": "A"
