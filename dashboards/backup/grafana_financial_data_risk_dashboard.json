          "rawQuery": true,
          "rawSql": "SELECT\n  dt,\n  hh,\n  rule_group,\n  rule_name,\n  metric_name,\n  validation_status,\n  severity,\n  observed_value,\n  expected_value,\n  diff_value,\n  note\nFROM validation_result\nWHERE profile_id = '${profile_id}'\n  AND validation_status IN ('warn', 'fail')\n  AND $__timeFilter(dt)\nORDER BY dt DESC, hh DESC, severity DESC",
