          "rawQuery": true,
          "rawSql": "SELECT dt AS time, 'validation_fail_count' AS metric, validation_fail_count AS value\nFROM data_risk_score_day\nWHERE profile_id = '${profile_id}' AND $__timeFilter(dt)\nUNION ALL\nSELECT dt AS time, 'validation_warn_count' AS metric, validation_warn_count AS value\nFROM data_risk_score_day\nWHERE profile_id = '${profile_id}' AND $__timeFilter(dt)\nUNION ALL\nSELECT dt AS time, 'drift_alert_count' AS metric, drift_alert_count AS value\nFROM data_risk_score_day\nWHERE profile_id = '${profile_id}' AND $__timeFilter(dt)\nUNION ALL\nSELECT dt AS time, 'drift_warn_count' AS metric, drift_warn_count AS value\nFROM data_risk_score_day\nWHERE profile_id = '${profile_id}' AND $__timeFilter(dt)\nORDER BY time",
          "refId": "A"
