          "rawQuery": true,
          "rawSql": "SELECT\n  dt AS time,\n  'drift_alert_count' AS metric,\n  SUM(CASE WHEN drift_status = 'alert' THEN 1 ELSE 0 END) AS value\nFROM metric_drift_result_r\nWHERE profile_id = '${profile_id}'\n  AND $__timeFilter(dt)\nGROUP BY dt\nUNION ALL\nSELECT\n  dt AS time,\n  'drift_warn_count' AS metric,\n  SUM(CASE WHEN drift_status = 'warn' THEN 1 ELSE 0 END) AS value\nFROM metric_drift_result_r\nWHERE profile_id = '${profile_id}'\n  AND $__timeFilter(dt)\nGROUP BY dt\nORDER BY time",
