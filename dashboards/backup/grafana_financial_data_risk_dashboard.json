    {
      "id": 1,
      "title": "Daily Risk Score",
      "type": "stat",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT risk_score AS value\nFROM data_risk_score_day\nWHERE profile_id = '${profile_id}'\nORDER BY dt DESC\nLIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 6
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Current Risk Status",
      "type": "stat",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE risk_status\n  WHEN 'normal' THEN 0\n  WHEN 'warning' THEN 1\n  WHEN 'alert' THEN 2\n  ELSE -1\nEND AS value\nFROM data_risk_score_day\nWHERE profile_id = '${profile_id}'\nORDER BY dt DESC\nLIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NORMAL",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "WARNING",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "ALERT",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      }
    },
