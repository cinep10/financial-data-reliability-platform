        }
      },
      {
        "name": "model_version",
        "type": "query",
        "label": "model_version",
        "hide": 0,
        "datasource": {
          "type": "mysql",
          "uid": "${DS_MYSQL}"
        },
        "definition": "SELECT DISTINCT model_version FROM ml_prediction_result ORDER BY model_version",
        "query": "SELECT DISTINCT model_version FROM ml_prediction_result ORDER BY model_version",
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": true,
