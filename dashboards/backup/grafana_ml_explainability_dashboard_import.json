        },
        "definition": "SELECT DISTINCT profile_id FROM ml_feature_vector_day ORDER BY profile_id",
        "query": "SELECT DISTINCT profile_id FROM ml_feature_vector_day ORDER BY profile_id",
        "refresh": 1,
