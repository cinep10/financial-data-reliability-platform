      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE LOWER(predicted_risk_status)\n  WHEN 'normal' THEN 0\n  WHEN 'warning' THEN 1\n  WHEN 'alert' THEN 2\n  ELSE -1\nEND AS value\nFROM ml_prediction_result\nWHERE profile_id='${profile_id}' AND $__timeFilter(dt)\nORDER BY dt DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "-1": {
                  "text": "NO DATA",
                  "color": "gray"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NORMAL",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "WARNING",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "ALERT",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
