    {
      "id": 3,
      "title": "Latest Predicted Risk Status",
      "type": "stat",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 5
