      "datasource": {
        "type": "mysql",
        "uid": "${DS_MARIADB}"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT incident_level FROM ai_incident_summary_day WHERE profile_id = '${profile_id}' ORDER BY dt DESC LIMIT 1"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
