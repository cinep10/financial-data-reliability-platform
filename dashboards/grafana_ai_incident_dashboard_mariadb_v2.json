          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT UNIX_TIMESTAMP(dt) AS time, predicted_alert_prob AS value FROM ai_incident_summary_day WHERE profile_id = '${profile_id}' ORDER BY dt DESC LIMIT 1"
