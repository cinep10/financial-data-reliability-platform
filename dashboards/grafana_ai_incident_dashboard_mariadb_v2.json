    {
      "id": 5,
      "type": "timeseries",
      "title": "AI Incident Level Trend",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MARIADB}"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT UNIX_TIMESTAMP(dt) AS time, CASE incident_level WHEN 'normal' THEN 0 WHEN 'warning' THEN 1 WHEN 'alert' THEN 2 ELSE 0 END AS value FROM ai_incident_summary_day WHERE profile_id = '${profile_id}' AND $__timeFilter(dt) ORDER BY dt"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Confidence Score vs Predicted Alert Probability",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MARIADB}"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT UNIX_TIMESTAMP(dt) AS time, confidence_score AS value, 'confidence_score' AS metric FROM ai_incident_summary_day WHERE profile_id = '${profile_id}' AND $__timeFilter(dt) UNION ALL SELECT UNIX_TIMESTAMP(dt) AS time, predicted_alert_prob AS value, 'predicted_alert_prob' AS metric FROM ai_incident_summary_day WHERE profile_id = '${profile_id}' AND $__timeFilter(dt) ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "AI Incident Summary Detail",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MARIADB}"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT dt, incident_level, incident_title, confidence_score, llm_model, executive_summary, technical_summary, business_impact FROM ai_incident_summary_day WHERE profile_id = '${profile_id}' AND $__timeFilter(dt) ORDER BY dt DESC LIMIT 50"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "AI Recommended Actions",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MARIADB}"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT dt, action_rank, action_type, action_title, priority, owner_hint, evidence, action_detail FROM ai_recommended_action_day WHERE profile_id = '${profile_id}' AND $__timeFilter(dt) ORDER BY dt DESC, action_rank ASC LIMIT 200"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "ML vs AI Decision Alignment",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MARIADB}"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT p.dt, p.predicted_risk_status, p.prob_alert, p.prob_warning, p.prob_normal, a.incident_level, a.incident_title FROM ml_prediction_result p JOIN ai_incident_summary_day a ON p.profile_id = a.profile_id AND p.dt = a.dt WHERE p.profile_id = '${profile_id}' AND $__timeFilter(p.dt) ORDER BY p.dt DESC LIMIT 100"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Action Type Distribution",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MARIADB}"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT action_type, COUNT(*) AS action_count FROM ai_recommended_action_day WHERE profile_id = '${profile_id}' AND $__timeFilter(dt) GROUP BY action_type ORDER BY action_count DESC"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    }
